generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// Runtime (ex.: Supabase pooler / PgBouncer na porta 6543)
  url       = env("DATABASE_URL")
  /// Migrações e operações que exigem conexão direta (ex.: POSTGRES_URL_NON_POOLING no Supabase)
  directUrl = env("DIRECT_URL")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  ANALYST
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         AdminRole @default(ANALYST)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  resource   String?
  metadata   Json?
  ipMasked   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  /// page_view | click | conversion | custom
  type      String
  name      String
  path      String?
  locale    String?
  payload   Json?
  /// chave anónima por visitante (hash no cliente)
  visitorKey String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type, name])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  company   String
  phone     String?
  intent    String
  message   String
  consent   Boolean      @default(false)
  sourcePath String?
  utm       Json?
  status    LeadStatus @default(NEW)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

model InsightReport {
  id         String   @id @default(cuid())
  periodKey  String   @unique
  contentMd  String
  model      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
